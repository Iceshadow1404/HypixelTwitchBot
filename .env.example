# Twitch bot account
TWITCH_OAUTH_TOKEN=oauth:YOUR_OAUTH_TOKEN_HERE
TWITCH_NICKNAME=your_bot_username
TWITCH_CHANNELS=channel1,channel2

# Twitch developer application (required unless LOCAL_MODE=true)
TWITCH_CLIENT_ID=YOUR_TWITCH_CLIENT_ID
TWITCH_CLIENT_SECRET=YOUR_TWITCH_CLIENT_SECRET

# Hypixel API key (https://developer.hypixel.net/)
HYPIXEL_API_KEY=YOUR_HYPIXEL_API_KEY

# Optional
PREFIX=#
LOCAL_MODE=false          # true: skip live-stream discovery, join only TWITCH_CHANNELS
LOG_LEVEL=INFO
DATA_DIR=./data           # where user_links.json is stored (Docker: /config)
NODE_SERVICE_URL=http://localhost:3000
